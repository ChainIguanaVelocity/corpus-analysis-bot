# .env file

# Telegram bot token
TELEGRAM_TOKEN=your_telegram_token_here

# Database file
DB_FILE=corpus_analysis.sqlite3

# Logging settings
LOG_LEVEL=INFO
LOG_FILE=app.log

# Text processing settings
MAX_TEXT_LENGTH=10000
TOP_WORDS=20

# Optional Yandex settings
# YANDEX_API_KEY=your_yandex_api_key_here
# YANDEX_API_URL=https://api.yandex.com/translate
