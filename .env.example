# .env.example — copy this file to .env and fill in your values

# Telegram Bot Token (obtain from @BotFather on Telegram)
TELEGRAM_TOKEN=your-telegram-bot-token-here

# SQLite database file path (default: corpus_analysis.sqlite3)
DB_FILE=corpus_analysis.sqlite3

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=app.log

# Analysis settings
MAX_TEXT_LENGTH=10000
TOP_WORDS=20

# Yandex Translate (optional — for Ossetian and other languages unsupported by Google)
# Without this key the free Yandex widget endpoint is used automatically (no account needed).
# Set this only if you need higher rate limits via Yandex Cloud Translate API v2:
# https://console.yandex.cloud/
# YANDEX_API_KEY=your-yandex-api-key-here

# Yandex AI (Yandex.GPT) — required for "🤖 Яндекс ИИ" explain and analyze features.
# Obtain an IAM token with: yc iam create-token
# YANDEX_IAM_TOKEN=your-iam-token-here
# Folder ID from Yandex Cloud console (used to construct the model URI automatically)
# YANDEX_FOLDER_ID=your-folder-id-here
# Optional: override the full model URI (e.g. gpt://<folder_id>/yandexgpt-lite)
# YANDEX_LLM_MODEL_URI=gpt://your-folder-id-here/yandexgpt-lite
